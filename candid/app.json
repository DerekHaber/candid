{
  "expo": {
    "name": "Candid",
    "slug": "candid",
    "scheme": "candid",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Candid to access your camera to take photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Candid to save your developed photos.",
          "savePhotosPermission": "Allow Candid to save photos to your library."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Candid to access your photos to set a profile picture."
        }
      ],
      "expo-router",
      "expo-notifications",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18c8d9e1-0b78-4367-9d7e-8b78b64b3eb5"
      }
    },
    "owner": "derekhaber04",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/18c8d9e1-0b78-4367-9d7e-8b78b64b3eb5"
    },
    "icon": "./assets/icon.png",
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1c2a40"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.derekhaber04.candid",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
